      <Dataset id="ds_noicap">
        <ColumnInfo>
          <Column id="code" type="STRING" size="50"/>
          <Column id="name" type="STRING" size="50"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">24</Col>
            <Col id="name">Lào Cai</Col>
          </Row>
          <Row>
            <Col id="code">01</Col>
            <Col id="name">Hà Nội</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[this.QuanLySinhVien_onload = function(obj:nexacro.Form, e:nexacro.LoadEventInfo)
{
    this.fn_fetchStudentData();
};
this.fn_fetchStudentData = function()
{
    var savedData = nexacro.getPrivateProfile("DB_SINHVIEN_MOCK");
    
    if (savedData && savedData !== "") {
        this.fn_bindStudentProfile();
        this.fn_updateAvatarUI();
        return; 
    }
    var sUrl = "https://cef03a03-a6eb-4f84-9a3f-1c9cd39b4977.mock.pstmn.io/getStudentProfile";
    var objXhr = new XMLHttpRequest();
    var pThis = this; 

    objXhr.onreadystatechange = function() {
        if (objXhr.readyState === 4 && objXhr.status === 200) {
            var responseJson;
            try {
                responseJson = JSON.parse(objXhr.responseText);
            } catch (err) {
                alert("Lỗi dữ liệu API (JSON): " + err.message);
                return;
            }
            
            if (responseJson && responseJson.ds_student_profile) {
                pThis.fn_populateDataset(responseJson.ds_student_profile);
                nexacro.setPrivateProfile("DB_SINHVIEN_MOCK", pThis.ds_sinhVien.saveXML());
            }
        }
    };

    objXhr.open("GET", sUrl, true);
    objXhr.send();
};

this.fn_populateDataset = function(arrData)
{
    var ds = this.ds_sinhVien;
    ds.clearData(); 

    if (arrData && arrData.length > 0) {
        var nRow = ds.addRow();
        var dataItem = arrData[0]; 
        for (var key in dataItem) {
            if (ds.getColIndex(key) >= 0) {
                ds.setColumn(nRow, key, dataItem[key] || "");
            }
        }
    }

    this.fn_bindStudentProfile();
    this.fn_updateAvatarUI();
};

this.setupCombo = function(combo, dsid, codecol, datacol) {
    if (combo && !combo._dataset_binded) {
        combo.set_innerdataset(dsid);
        combo.set_codecolumn(codecol);
        combo.set_datacolumn(datacol);
        combo._dataset_binded = true;
    }
};

this.fn_bindStudentProfile = function()
{
    var divLeft;
    if (this.div_left) divLeft = this.div_left;
    else if (this.div_scroll && this.div_scroll.form.div_left) divLeft = this.div_scroll.form.div_left;
    
    if (!divLeft) return;

    var f = divLeft.form;
    if(f.cmb_gioitinh) this.setupCombo(f.cmb_gioitinh, "ds_gioitinh", "code", "name");
    if(f.cmb_honnhan) this.setupCombo(f.cmb_honnhan, "ds_honnhan", "code", "name");
    if(f.cmb_xuatthan) this.setupCombo(f.cmb_xuatthan, "ds_xuatthan", "code", "name");
    if(f.cmb_dantoc) this.setupCombo(f.cmb_dantoc, "ds_dantoc", "code", "name");
    if(f.cmb_tongiao) this.setupCombo(f.cmb_tongiao, "ds_tongiao", "code", "name");
    if(f.cmb_quoctich) this.setupCombo(f.cmb_quoctich, "ds_quoctich", "code", "name");
    if(f.cmb_noicap) this.setupCombo(f.cmb_noicap, "ds_noicap", "code", "name");
};

this.fn_updateAvatarUI = function()
{
    var divRight;
    if (this.div_right) divRight = this.div_right;
    else if (this.div_scroll && this.div_scroll.form.div_right) divRight = this.div_scroll.form.div_right;   
    if (!divRight) return; 
    var imgComp = divRight.form.img_avatar; 
    if(!imgComp && divRight.form.div_avatarCard) {
        imgComp = divRight.form.div_avatarCard.form.img_avatar;
    }

    if (!imgComp) return;

    var sAvatarUrl = this.ds_sinhVien.getColumn(0, "AVATAR_URL");
    var sGender    = this.ds_sinhVien.getColumn(0, "GIOI_TINH");

    if (sAvatarUrl && sAvatarUrl !== "") {
        imgComp.set_image(sAvatarUrl);
    } else {
        imgComp.set_image(sGender === "M" ? "imagerc::photo_men.png" : "imagerc::photo_women.png");
    }
};
this.fn_checkValidation = function()
{
    var ds = this.ds_sinhVien;
    var arrRequired = [
        { colId: "MA_NHAN_VIEN", name: "Mã nhân viên" },
        { colId: "HO", name: "Họ" },
        { colId: "TEN", name: "Tên" },
        { colId: "GIOI_TINH", name: "Giới tính" },
        { colId: "NGAY_SINH", name: "Ngày sinh" }
    ];

    for (var i = 0; i < arrRequired.length; i++) {
        var sValue = ds.getColumn(0, arrRequired[i].colId);
        if (!sValue || String(sValue).trim() === "") {
            alert("Vui lòng nhập đầy đủ: " + arrRequired[i].name);
            return false; 
        }
    }
    return true;
};
this.btn_submit_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
    if (this.fn_checkValidation()) {
        nexacro.setPrivateProfile("DB_SINHVIEN_MOCK", sDataXML);
        
        alert("Cập nhật thành công");
    }
};

this.fn_saveStudentData = function()
{
    alert("Dữ liệu đã được đóng gói chuẩn bị gửi lên Server!");
};

this.btn_addAvatar_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
    var fileDialog = new nexacro.FileDialog("fileDialog_avatar", this);
    fileDialog.set_accept(".png, .jpg, .jpeg, .gif, image/*");
    fileDialog.addEventHandler("onclose", this.fileDialog_onclose, this);
    fileDialog.open('Chọn ảnh đại diện Nexacro', nexacro.FileDialog.LOAD);
};
this.fileDialog_onclose = function(obj:nexacro.FileDialog, e:nexacro.FileDialogEventInfo)
{
    if (e.virtualfiles && e.virtualfiles.length > 0) {
        var vFile = e.virtualfiles[0]; 
        vFile.clearEventHandler("onsuccess");
        vFile.clearEventHandler("onerror");     
        vFile.addEventHandler("onsuccess", function(vf, evt) {
            if (evt.reason == 1) { 
                vf.read(); 
            }
            else if (evt.reason == 3) { 
                var ext = vf.filename.split('.').pop().toLowerCase();
                var mime = "image/png";
                if (ext === "jpg" || ext === "jpeg") mime = "image/jpeg";
                else if (ext === "gif") mime = "image/gif";
                var rawData = evt.binarydata ? evt.binarydata : evt.textdata;
                var base64 = "data:" + mime + ";base64," + nexacro.base64Encode(rawData);
                this.ds_sinhVien.setColumn(0, "AVATAR_URL", base64);
                this.fn_updateAvatarUI();
                vf.close(); 
            }
        }, this);
        
        vFile.addEventHandler("onerror", function(vf, evt) {
            alert("Lỗi đọc file: " + evt.errormsg);
            vf.close(); 
        }, this);
                vFile.open(null, nexacro.VirtualFile.openRead);
    }
};

this.btn_removeAvatar_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
    if (this.confirm("Bạn có chắc chắn muốn xóa ảnh đại diện hiện tại không?", "Xác nhận xóa")) {
        this.ds_sinhVien.setColumn(0, "AVATAR_URL", "");   
        this.fn_updateAvatarUI();
    }
};

this.nvl = function(val)
{
    if (val == null || val == undefined) return "";
    return String(val).trim();
};
this.div_scroll_div_right_img_avatar_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
	
};
]]></Script>
    <Layouts>
