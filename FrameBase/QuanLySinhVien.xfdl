            <Col id="name">Nông dân</Col>
          </Row>
          <Row>
            <Col id="code">02</Col>
            <Col id="name">Trí thức</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="ds_dantoc">
        <ColumnInfo>
          <Column id="code" type="STRING" size="30"/>
          <Column id="name" type="STRING" size="30"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">01</Col>
            <Col id="name">Kinh</Col>
          </Row>
          <Row>
            <Col id="code">02</Col>
            <Col id="name">Tày</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="ds_tongiao">
        <ColumnInfo>
          <Column id="code" type="STRING" size="30"/>
          <Column id="name" type="STRING" size="30"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">00</Col>
            <Col id="name">Không</Col>
          </Row>
          <Row>
            <Col id="code">01</Col>
            <Col id="name">Phật giáo</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="ds_quoctich">
        <ColumnInfo>
          <Column id="code" type="STRING" size="30"/>
          <Column id="name" type="STRING" size="30"/>
