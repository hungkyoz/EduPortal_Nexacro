                    <Static id="st_ns_lbl" left="360" top="150" width="80" height="22" text="Ngày sinh" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Static id="st_ns_req" left="440" top="150" width="8" height="22" text="*" font="12px Arial" color="red" textAlign="left" verticalAlign="middle"/>
                    <Calendar id="cal_ngaysinh" left="448" top="148" width="200" height="24" dateformat="dd/MM/yyyy" border="1px solid #b0b8c8" background="white" font="12px Arial"/>
                    <Static id="st_hn_lbl" left="8" top="184" width="100" height="22" text="Hôn nhân" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Combo id="cmb_honnhan" left="120" top="182" width="200" height="24" innerdataset="ds_honnhan" codecolumn="code" datacolumn="name" border="1px solid #b0b8c8" background="white" font="12px Arial"/>
                    <Static id="st_xt_lbl" left="360" top="184" width="80" height="22" text="Xuất thân" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Combo id="cmb_xuatthan" left="448" top="182" width="200" height="24" innerdataset="ds_xuatthan" codecolumn="code" datacolumn="name" border="1px solid #b0b8c8" background="white" font="12px Arial"/>
                    <Static id="st_dt_lbl" left="8" top="218" width="100" height="22" text="Dân tộc" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Combo id="cmb_dantoc" left="120" top="216" width="200" height="24" innerdataset="ds_dantoc" codecolumn="code" datacolumn="name" border="1px solid #b0b8c8" background="white" font="12px Arial"/>
                    <Static id="st_tg_lbl" left="360" top="218" width="80" height="22" text="Tôn giáo" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Combo id="cmb_tongiao" left="448" top="216" width="200" height="24" innerdataset="ds_tongiao" codecolumn="code" datacolumn="name" border="1px solid #b0b8c8" background="white" font="12px Arial"/>
                    <Line id="line_div1" left="8" top="252" width="744" height="1" border="1px dashed #d0d8e8"/>
                    <Static id="st_qt_lbl" left="8" top="266" width="100" height="22" text="Quốc tịch" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Combo id="cmb_quoctich" left="120" top="264" width="200" height="24" innerdataset="ds_quoctich" codecolumn="code" datacolumn="name" border="1px solid #b0b8c8" background="white" font="12px Arial"/>
                    <Static id="st_cmt_lbl" left="360" top="266" width="80" height="22" text="CMND/CCCD" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Edit id="edt_cmt" left="448" top="264" width="200" height="24" border="1px solid #b0b8c8" background="white" font="12px Arial" padding="0px 0px 0px 6px"/>
                    <Static id="st_ngaycmt_lbl" left="8" top="300" width="100" height="22" text="Ngày cấp" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Calendar id="cal_ngaycmt" left="120" top="298" width="200" height="24" dateformat="dd/MM/yyyy" border="1px solid #b0b8c8" background="white" font="12px Arial"/>
                    <Static id="st_noicap_lbl" left="360" top="300" width="80" height="22" text="Nơi cấp" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Combo id="cmb_noicap" left="448" top="298" width="200" height="24" innerdataset="ds_noicap" codecolumn="code" datacolumn="name" border="1px solid #b0b8c8" background="white" font="12px Arial"/>
                    <Static id="st_shc_lbl" left="8" top="334" width="100" height="22" text="Số hộ chiếu" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Edit id="edt_sohochieu" left="120" top="332" width="200" height="24" border="1px solid #b0b8c8" background="white" font="12px Arial" padding="0px 0px 0px 6px"/>
                    <Static id="st_ngaycap_lbl" left="360" top="334" width="80" height="22" text="Ngày cấp" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Calendar id="cal_ngaycap" left="448" top="332" width="200" height="24" dateformat="dd/MM/yyyy" border="1px solid #b0b8c8" background="white" font="12px Arial"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="div_right" left="770" top="0" width="280" height="620" background="white" border="0px none, 0px none, 0px none, 1px solid #d0d8e8">
                <Layouts>
                  <Layout>
                    <Div id="div_avatarCard" left="20" top="15" width="230" height="250" background="white" border="1px solid #d0d8e8" borderRadius="4px">
                      <Layouts>
                        <Layout>
                          <ImageViewer id="img_avatar" left="15" top="15" right="15" height="175" border="1px solid #e0e0e0" stretch="fit" image="url('..\_resource_\_images_\photo_men.png')" background="#f8f9fa"/>
                          <Div id="div_avatarAction" left="0" bottom="0" right="0" height="45" background="#f4f7fa" border="1px solid #d0d8e8, 0px none, 0px none, 0px none">
                            <Layouts>
                              <Layout>
                                <Button id="btn_addAvatar" left="15" top="7" width="35" height="30" text="+" font="bold 18px Arial" color="#0a467a" background="#e6f0fa" border="1px solid #b3d0ee" borderRadius="4px" cursor="hand" onclick="btn_addAvatar_onclick"/>
                                <Button id="btn_removeAvatar" left="60" top="7" width="35" height="30" text="-" font="bold 18px Arial" color="#0a467a" background="#e6f0fa" border="1px solid #b3d0ee" borderRadius="4px" cursor="hand" onclick="btn_removeAvatar_onclick"/>
                              </Layout>
                            </Layouts>
                          </Div>
                        </Layout>
                      </Layouts>
                    </Div>
                    <Div id="div_lienhe" left="20" top="285" width="230" height="170" background="white" border="1px solid #d0d8e8" borderRadius="4px">
                      <Layouts>
                        <Layout>
                          <Static id="st_lienhe_title" left="0" top="0" right="0" height="35" text="Liên hệ" font="bold 12px Arial" color="#333333" background="#f4f7fa" border="0px none, 0px none, 1px solid #d0d8e8, 0px none" padding="0px 0px 0px 15px"/>
                          <Static id="st_email_lbl" left="15" top="45" width="100" height="20" text="Email" font="bold 11px Arial" color="#555555"/>
                          <Edit id="edt_email" left="15" top="65" right="15" height="30" border="1px solid #a6b5cc" borderRadius="3px" background="white" font="12px Arial" padding="0px 0px 0px 10px" dataset="ds_sinhVien" datacolumn="email"/>
                          <Static id="st_didong_lbl" left="15" top="105" width="100" height="20" text="Di động" font="bold 11px Arial" color="#555555"/>
                          <Edit id="edt_didong" left="15" top="125" right="15" height="30" border="1px solid #a6b5cc" borderRadius="3px" background="white" font="12px Arial" padding="0px 0px 0px 10px" dataset="ds_sinhVien" datacolumn="didong"/>
                        </Layout>
                      </Layouts>
                    </Div>
                  </Layout>
                </Layouts>
              </Div>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/* ================================================================
   QuanLySinhVien.xjs
   Script tách riêng cho form Quản Lý Sinh Viên
   ================================================================ */

this.QuanLySinhVien_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
    this.fn_initForm();
    this.fn_bindData();
    this.fn_setDefaultAvatar();
};

/* ----------------------------------------------------------------
   KHỞI TẠO FORM
   ---------------------------------------------------------------- */
this.fn_initForm = function()
{
    // Set focus vào field đầu tiên (Phải có this. và .form)
    this.div_scroll.form.div_left.form.edt_manhanvien.setFocus();

    // Set style required fields
    this.fn_setRequiredStyle("edt_manhanvien");
    this.fn_setRequiredStyle("edt_ho");
    this.fn_setRequiredStyle("cmb_gioitinh");
    this.fn_setRequiredStyle("cal_ngaysinh");
};

this.fn_setRequiredStyle = function(sId)
{
    // Logic highlight viền đỏ cho các ô bắt buộc
};

/* ----------------------------------------------------------------
   BIND DATA VÀO CONTROLS
   ---------------------------------------------------------------- */
this.fn_bindData = function()
{
    var ds = this.ds_sinhVien;
    if (ds.rowcount == 0) {
        ds.addRow();
    }
    trace("fn_bindData: manhanvien = " + ds.getColumn(0, "manhanvien"));
};

/* ----------------------------------------------------------------
   SET AVATAR MẶC ĐỊNH
   ---------------------------------------------------------------- */
this.fn_setDefaultAvatar = function()
{
    var img = this.div_scroll.form.div_right.form.div_avatarCard.form.img_avatar;
    if (img) {
        // Đã sửa lại đường dẫn chuẩn, đảm bảo gọi đúng ảnh có thật trong dự án
        img.set_image("imagerc::photo_men.png");
    }
};

/* ----------------------------------------------------------------
   NÚT THÊM AVATAR (+)
   ---------------------------------------------------------------- */
this.btn_addAvatar_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    // Đã cập nhật đường dẫn cho đồng nhất
    var sFile = "imagerc::photo_men.png"; 
    
    var img = this.div_scroll.form.div_right.form.div_avatarCard.form.img_avatar;
    img.set_image(sFile);

    // Lưu đường dẫn vào dataset
    this.ds_sinhVien.setColumn(0, "avatar", sFile);
    trace("Avatar đã đổi thành: " + sFile);
};

/* ----------------------------------------------------------------
   NÚT XÓA AVATAR (−)
   ---------------------------------------------------------------- */
this.btn_removeAvatar_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    var nRet = this.confirm("Bạn có muốn xóa ảnh đại diện không?", "Xác nhận");

    if (nRet) { // YES
        var img = this.div_scroll.form.div_right.form.div_avatarCard.form.img_avatar;
        // Gán lại về ảnh mặc định chuẩn
        img.set_image("imagerc::photo_men.png");
        this.ds_sinhVien.setColumn(0, "avatar", "");
        trace("Avatar đã xóa.");
    }
};

/* ----------------------------------------------------------------
   VALIDATE FORM TRƯỚC KHI LƯU
   ---------------------------------------------------------------- */
this.fn_validate = function()
{
    var ds = this.ds_sinhVien;
    var row = 0;

    if (this.nvl(ds.getColumn(row, "manhanvien")) == "") {
        alert("Vui lòng nhập Mã nhân viên.");
        this.div_scroll.form.div_left.form.edt_manhanvien.setFocus();
        return false;
    }
    if (this.nvl(ds.getColumn(row, "ho")) == "") {
        alert("Vui lòng nhập Họ.");
        this.div_scroll.form.div_left.form.edt_ho.setFocus();
        return false;
    }
    if (this.nvl(ds.getColumn(row, "ten")) == "") {
        alert("Vui lòng nhập Tên.");
        this.div_scroll.form.div_left.form.edt_ten.setFocus();
        return false;
    }
    if (this.nvl(ds.getColumn(row, "gioitinh")) == "") {
        alert("Vui lòng chọn Giới tính.");
        this.div_scroll.form.div_left.form.cmb_gioitinh.setFocus();
        return false;
    }
    if (this.nvl(ds.getColumn(row, "ngaysinh")) == "") {
        alert("Vui lòng nhập Ngày sinh.");
        this.div_scroll.form.div_left.form.cal_ngaysinh.setFocus();
        return false;
    }
    return true;
};

/* ----------------------------------------------------------------
   UTILITY: NVL (null/empty check)
   ---------------------------------------------------------------- */
this.nvl = function(val)
{
    if (val == null || val == undefined) return "";
    return String(val).trim();
};

/* ----------------------------------------------------------------
   CLICK AVATAR (GIỮ LẠI ĐỂ TRÁNH LỖI)
   ---------------------------------------------------------------- */
this.div_scroll_div_right_div_avatarCard_img_avatar_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
    // Hàm này được giữ lại phòng trường hợp trong XML bạn chưa xóa sự kiện onclick ở ảnh
};]]></Script>
  </Form>
</FDL>
