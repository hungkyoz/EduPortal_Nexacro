                          <Edit id="edt_email" left="15" top="63" right="15" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="EMAIL"/>
                          <Static id="st_didong_lbl" left="15" top="103" width="100" height="20" text="Di động" font="bold 11px Arial" color="#555555"/>
                          <Edit id="edt_didong" left="15" top="123" right="15" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="DI_DONG"/>
                        </Layout>
                      </Layouts>
                    </Div>
                    <Button id="btn_back" left="20" top="480" width="110" height="36" text="Quay lại" font="bold 12px Arial" color="#1a5db5" background="#e4f1fd" border="1px solid #b3d4f5" borderRadius="4px" cursor="hand" onclick="btn_back_onclick"/>
                    <Button id="btn_submit" left="145" top="480" width="110" height="36" text="Cập nhật" font="bold 12px Arial" color="white" background="#1a5db5" border="0px none" borderRadius="4px" cursor="hand" onclick="btn_submit_onclick"/>
                  </Layout>
                </Layouts>
              </Div>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Bind>
