    <Layouts>
      <Layout height="650" width="1060">
        <Div id="div_scroll" left="0" top="0" width="1060" height="650" background="white">
          <Layouts>
            <Layout>
              <Div id="div_left" left="30" top="10" width="730" height="600" background="white" border="1px solid #dde3ec" borderRadius="6px" text="">
                <Layouts>
                  <Layout>
                    <Static id="st_manv_lbl" left="20" top="20" width="90" height="32" text="Mã nhân viên *" usedecorate="true" font="12px Arial" color="#333333" textAlign="left"/>
                    <Edit id="edt_manhanvien" left="120" top="20" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="manhanvien"/>
                    <Static id="st_sothe_lbl" left="380" top="20" width="90" height="32" text="Số thẻ" font="12px Arial" color="#333333" textAlign="left"/>
                    <Edit id="edt_sothe" left="480" top="20" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="sothe"/>
                    <Static id="st_sohs_lbl" left="20" top="65" width="90" height="32" text="Số hồ sơ" font="12px Arial" color="#333333" textAlign="left"/>
                    <Edit id="edt_sohoso" left="120" top="65" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="sohoso"/>
                    <Static id="st_muchs_lbl" left="380" top="65" width="90" height="32" text="Mức hồ sơ" font="12px Arial" color="#333333" textAlign="left"/>
                    <Spin id="spin_muchoso" left="480" top="65" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="muchoso"/>
                    <Static id="st_hovaten_lbl" left="20" top="110" width="90" height="32" text="Họ và tên *" usedecorate="true" font="12px Arial" color="#333333" textAlign="left"/>
                    <Edit id="edt_ho" left="120" top="110" width="150" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="ho"/>
                    <Edit id="edt_tendem" left="280" top="110" width="150" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="ten_dem"/>
                    <Edit id="edt_ten" left="440" top="110" width="270" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="ten"/>
                    <Static id="st_tengoi_lbl" left="20" top="155" width="90" height="32" text="Tên gọi khác" font="12px Arial" color="#333333" textAlign="left"/>
                    <Edit id="edt_tengoi" left="120" top="155" width="590" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="tengoi"/>
                    <Static id="st_gt_lbl" left="20" top="200" width="90" height="32" text="Giới tính *" usedecorate="true" font="12px Arial" color="#333333" textAlign="left"/>
                    <Combo id="cmb_gioitinh" left="120" top="200" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="gioitinh" innerdataset="ds_gioitinh" codecolumn="code" displaycolumn="name"/>
                    <Static id="st_ns_lbl" left="380" top="200" width="90" height="32" text="Ngày sinh *" usedecorate="true" font="12px Arial" color="#333333" textAlign="left"/>
                    <Calendar id="cal_ngaysinh" left="480" top="200" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="ngaysinh"/>
                    <Static id="st_hn_lbl" left="20" top="245" width="90" height="32" text="Hôn nhân" font="12px Arial" color="#333333" textAlign="left"/>
                    <Combo id="cmb_honnhan" left="120" top="245" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="honnhan" innerdataset="ds_honnhan" codecolumn="code" displaycolumn="name"/>
                    <Static id="st_xt_lbl" left="380" top="245" width="90" height="32" text="Xuất thân" font="12px Arial" color="#333333" textAlign="left"/>
                    <Combo id="cmb_xuatthan" left="480" top="245" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="xuatthan" innerdataset="ds_xuatthan" codecolumn="code" displaycolumn="name"/>
                    <Static id="st_dt_lbl" left="20" top="290" width="90" height="32" text="Dân tộc" font="12px Arial" color="#333333" textAlign="left"/>
                    <Combo id="cmb_dantoc" left="120" top="290" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="dantoc" innerdataset="ds_dantoc" codecolumn="code" displaycolumn="name"/>
                    <Static id="st_tg_lbl" left="380" top="290" width="90" height="32" text="Tôn giáo" font="12px Arial" color="#333333" textAlign="left"/>
                    <Combo id="cmb_tongiao" left="480" top="290" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="tongiao" innerdataset="ds_tongiao" codecolumn="code" displaycolumn="name"/>
                    <Line id="line_sep" left="20" top="335" right="20" height="1" border="1px dashed #c8d0dc"/>
                    <Static id="st_qt_lbl" left="20" top="350" width="90" height="32" text="Quốc tịch" font="12px Arial" color="#333333" textAlign="left"/>
                    <Combo id="cmb_quoctich" left="120" top="350" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="quoctich" innerdataset="ds_quoctich" codecolumn="code" displaycolumn="name"/>
                    <Static id="st_cmt_lbl" left="380" top="350" width="90" height="32" text="CMND/CCCD" font="12px Arial" color="#333333" textAlign="left"/>
                    <Edit id="edt_cmt" left="480" top="350" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="cmt"/>
                    <Static id="st_ngaycmt_lbl" left="20" top="395" width="90" height="32" text="Ngày cấp" font="12px Arial" color="#333333" textAlign="left"/>
                    <Calendar id="cal_ngaycmt" left="120" top="395" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="ngaycmt"/>
                    <Static id="st_noicap_lbl" left="380" top="395" width="90" height="32" text="Nơi cấp" font="12px Arial" color="#333333" textAlign="left"/>
                    <Combo id="cmb_noicap" left="480" top="395" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="noicap" innerdataset="ds_noicap" codecolumn="code" displaycolumn="name"/>
                    <Static id="st_shc_lbl" left="20" top="440" width="90" height="32" text="Số hộ chiếu" font="12px Arial" color="#333333" textAlign="left"/>
                    <Edit id="edt_sohochieu" left="120" top="440" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="sohochieu"/>
                    <Static id="st_ngaycap_lbl" left="380" top="440" width="90" height="32" text="Ngày cấp" font="12px Arial" color="#333333" textAlign="left"/>
                    <Calendar id="cal_ngaycap" left="480" top="440" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="ngaycap"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="div_right" left="770" top="0" width="280" height="620" background="white" border="0px none, 0px none, 0px none, 1px solid #d0d8e8">
                <Layouts>
                  <Layout>
                    <Div id="div_avatarCard" left="20" top="15" width="230" height="255" background="white" border="1px solid #d0d8e8" borderRadius="4px">
                      <Layouts>
                        <Layout>
                          <ImageViewer id="img_avatar" left="15" top="15" right="15" height="180" border="1px solid #e0e0e0" stretch="fit" image="imagerc::photo_men.png" background="#f8f9fa"/>
                          <Div id="div_avatarAction" left="0" bottom="0" right="0" height="50" background="#f4f7fa" border="1px solid #d0d8e8, 0px none, 0px none, 0px none">
                            <Layouts>
                              <Layout>
                                <Button id="btn_addAvatar" left="18" top="9" width="32" height="32" text="+" font="bold 18px Arial" color="white" background="#1976d2" border="0px none" borderRadius="16px" cursor="hand" onclick="btn_addAvatar_onclick"/>
                                <Button id="btn_removeAvatar" left="58" top="9" width="32" height="32" text="-" font="bold 22px Arial" color="white" background="#e53935" border="0px none" borderRadius="16px" cursor="hand" onclick="btn_removeAvatar_onclick"/>
                              </Layout>
                            </Layouts>
                          </Div>
                        </Layout>
                      </Layouts>
                    </Div>
                    <Div id="div_lienhe" left="20" top="290" width="230" height="170" background="white" border="1px solid #d0d8e8" borderRadius="4px">
                      <Layouts>
                        <Layout>
                          <Static id="st_lienhe_title" left="0" top="0" right="0" height="35" text="Liên hệ" font="bold 12px Arial" color="#333333" background="#f4f7fa" border="0px none, 0px none, 1px solid #d0d8e8, 0px none" padding="0px 0px 0px 15px" verticalAlign="middle"/>
                          <Static id="st_email_lbl" left="15" top="43" width="100" height="20" text="Email" font="bold 11px Arial" color="#555555"/>
                          <Edit id="edt_email" left="15" top="63" right="15" height="28" border="1px solid #a6b5cc" borderRadius="3px" background="white" font="12px Arial" padding="0px 0px 0px 10px" dataset="ds_sinhVien" datacolumn="email"/>
                          <Static id="st_didong_lbl" left="15" top="103" width="100" height="20" text="Di động" font="bold 11px Arial" color="#555555"/>
                          <Edit id="edt_didong" left="15" top="123" right="15" height="28" border="1px solid #a6b5cc" borderRadius="3px" background="white" font="12px Arial" padding="0px 0px 0px 10px" dataset="ds_sinhVien" datacolumn="didong"/>
                        </Layout>
                      </Layouts>
                    </Div>
                  </Layout>
                </Layouts>
              </Div>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[this.QuanLySinhVien_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
    this.fn_initForm();
    this.fn_bindData();
};

this.fn_initForm = function()
{
    this.div_scroll.form.div_left.form.edt_manhanvien.setFocus();
};

this.fn_bindData = function()
{
    var ds = this.ds_sinhVien;
    if (ds.rowcount == 0) ds.addRow();
    trace("manhanvien=" + ds.getColumn(0, "manhanvien"));
    this.fn_setDefaultAvatar();
};

this.fn_setDefaultAvatar = function()
{
    var img = this.div_scroll.form.div_right.form.div_avatarCard.form.img_avatar;
    if (!img) return;
    var sAvatar = this.nvl(this.ds_sinhVien.getColumn(0, "avatar"));
    if (sAvatar != "") { img.set_image(sAvatar); return; }
    var sGt = this.nvl(this.ds_sinhVien.getColumn(0, "gioitinh"));
    img.set_image(sGt == "Nữ" ? "imagerc::photo_women.png" : "imagerc::photo_men.png");
};

this.btn_addAvatar_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    var sFile = "imagerc::photo_men.png";
    var img = this.div_scroll.form.div_right.form.div_avatarCard.form.img_avatar;
    img.set_image(sFile);
    this.ds_sinhVien.setColumn(0, "avatar", sFile);
};

this.btn_removeAvatar_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    if (this.confirm("Bạn có muốn xóa ảnh đại diện không?", "Xác nhận")) {
        this.ds_sinhVien.setColumn(0, "avatar", "");
        this.fn_setDefaultAvatar();
    }
};

this.fn_validate = function()
{
    var ds = this.ds_sinhVien;
    var f  = this.div_scroll.form.div_left.form;
    if (this.nvl(ds.getColumn(0,"manhanvien"))=="") { alert("Vui lòng nhập Mã nhân viên."); f.edt_manhanvien.setFocus(); return false; }
    if (this.nvl(ds.getColumn(0,"ho"))=="")         { alert("Vui lòng nhập Họ.");           f.edt_ho.setFocus();         return false; }
    if (this.nvl(ds.getColumn(0,"ten"))=="")        { alert("Vui lòng nhập Tên.");           f.edt_ten.setFocus();        return false; }
    if (this.nvl(ds.getColumn(0,"gioitinh"))=="")   { alert("Vui lòng chọn Giới tính.");    f.cmb_gioitinh.setFocus();   return false; }
    if (this.nvl(ds.getColumn(0,"ngaysinh"))=="")   { alert("Vui lòng nhập Ngày sinh.");    f.cal_ngaysinh.setFocus();   return false; }
    return true;
};

this.nvl = function(val)
{
    if (val == null || val == undefined) return "";
    return String(val).trim();
};

this.div_scroll_div_right_div_avatarCard_img_avatar_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo){};
this.div_scroll_div_left_st_sohs_lbl_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};

this.div_scroll_div_left_edt_manhanvien_onchanged = function(obj:nexacro.Edit,e:nexacro.ChangeEventInfo)
{
	
};
]]></Script>
  </Form>
</FDL>
