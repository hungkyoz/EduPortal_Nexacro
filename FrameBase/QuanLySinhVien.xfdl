            <Col id="xuatthan">Trí thức</Col>
            <Col id="dantoc">Kinh</Col>
            <Col id="tongiao">Không</Col>
            <Col id="quoctich">Việt Nam</Col>
            <Col id="cmt">060586034</Col>
            <Col id="ngaycmt">10/10/2009</Col>
