<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="QuanLySinhVien" width="1060" height="650" titletext="Quản Lý Sinh Viên" background="white" onload="QuanLySinhVien_onload">
    <Objects>
      <Dataset id="ds_sinhVien">
        <ColumnInfo>
          <Column id="manhanvien" type="STRING" size="20"/>
          <Column id="sothe" type="STRING" size="20"/>
          <Column id="sohoso" type="STRING" size="20"/>
          <Column id="muchoso" type="INT"/>
          <Column id="ho" type="STRING" size="50"/>
          <Column id="ten_dem" type="STRING" size="50"/>
          <Column id="ten" type="STRING" size="50"/>
          <Column id="tengoi" type="STRING" size="100"/>
          <Column id="gioitinh" type="STRING" size="10"/>
          <Column id="ngaysinh" type="STRING" size="20"/>
          <Column id="honnhan" type="STRING" size="20"/>
          <Column id="xuatthan" type="STRING" size="50"/>
          <Column id="dantoc" type="STRING" size="50"/>
          <Column id="tongiao" type="STRING" size="50"/>
          <Column id="quoctich" type="STRING" size="50"/>
          <Column id="cmt" type="STRING" size="20"/>
          <Column id="ngaycmt" type="STRING" size="20"/>
          <Column id="noicap" type="STRING" size="100"/>
