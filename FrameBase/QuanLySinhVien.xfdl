                    <Edit id="edt_manhanvien" left="120" top="12" width="200" height="24" border="1px solid #b0b8c8" background="white" font="12px Arial" padding="0px 0px 0px 6px"/>
                    <Static id="st_sothe_lbl" left="360" top="14" width="80" height="22" text="Số thẻ" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Edit id="edt_sothe" left="448" top="12" width="200" height="24" border="1px solid #b0b8c8" background="white" font="12px Arial" padding="0px 0px 0px 6px"/>
                    <Static id="st_sohs_lbl" left="8" top="48" width="100" height="22" text="Số hồ sơ" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
                    <Edit id="edt_sohoso" left="120" top="46" width="200" height="24" border="1px solid #b0b8c8" background="white" font="12px Arial" padding="0px 0px 0px 6px"/>
