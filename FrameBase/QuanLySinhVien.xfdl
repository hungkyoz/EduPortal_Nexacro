              <Div id="div_left" left="30" top="0" width="760" height="620" background="white">
                <Layouts>
                  <Layout>
                    <Static id="st_manv_lbl" left="8" top="14" width="100" height="22" text="Mã nhân viên" font="12px Arial" color="#333333" textAlign="right" verticalAlign="middle"/>
