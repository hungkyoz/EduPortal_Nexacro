                    <Static id="st_sothe_lbl" left="380" top="70" width="90" height="32" text="Số thẻ" font="12px Arial" color="#333333" textAlign="left"/>
                    <Edit id="edt_sothe" left="480" top="70" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="SO_THE"/>
                    <Static id="st_sohs_lbl" left="20" top="115" width="90" height="32" text="Số hồ sơ" font="12px Arial" color="#333333" textAlign="left"/>
                    <Edit id="edt_sohoso" left="120" top="115" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="SO_HO_SO"/>
