                    <Static id="st_ngaycap_lbl" left="380" top="490" width="90" height="32" text="Ngày cấp" font="12px Arial" color="#333333" textAlign="left"/>
                    <Calendar id="cal_ngaycap" left="480" top="490" width="230" height="32" border="1px solid #d0d8e8" borderRadius="4px" padding="0px 10px" dataset="ds_sinhVien" datacolumn="NGAY_CAP_HC"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="div_right" top="15" width="280" bottom="15" right="15" background="white" border="1px solid #dde3ec" borderRadius="6px">
                <Layouts>
                  <Layout>
                    <ImageViewer id="img_avatar" left="15" top="15" right="15" height="180" border="1px solid #e0e0e0" stretch="fit" image="imagerc::photo_men.png" background="#f8f9fa" onclick="div_scroll_div_right_img_avatar_onclick"/>
